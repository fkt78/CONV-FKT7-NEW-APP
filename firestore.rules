rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ヘルパー：管理者かどうか ──
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── 本人によるクーポン使用（unused→used）のみ許可。金額・テンプレID等の改ざんは不可 ──
    function isUserCouponMarkUsedOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedAt'])
        && resource.data.status == 'unused'
        && request.resource.data.status == 'used'
        && (resource.data.usedAt == null)
        && request.resource.data.usedAt is timestamp;
    }

    // ── ユーザー：本人のみ読み書き、管理者は全件読み取り可 ──
    // ※ role / status の書き換えは管理者のみ許可し、一般ユーザーの権限昇格を防止
    match /users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.keys().hasAny(['role'])
        && (!('memberGroups' in request.resource.data)
          || (request.resource.data.memberGroups is list
            && request.resource.data.memberGroups.size() == 0));
      allow update: if request.auth != null
        && (
          (request.auth.uid == uid
            && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
            && (!('status' in request.resource.data) || request.resource.data.status == resource.data.status)
            && (!('memberGroups' in request.resource.data) || request.resource.data.memberGroups == resource.data.memberGroups)
          )
          || isAdmin()
        );
      allow delete: if request.auth != null && isAdmin();
    }

    // ── ユーザー保有クーポン：本人または管理者が読み取り、本人は使用済み更新のみ、管理者は作成可 ──
    match /users/{uid}/coupons/{couponId} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && isAdmin();
      allow update: if request.auth != null
        && (isAdmin()
          || (request.auth.uid == uid && isUserCouponMarkUsedOnly()));
      allow delete: if false;
    }

    // ── チャット：本人または管理者のみ ──
    match /chats/{chatId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == chatId || isAdmin());
    }

    // ── チャットメッセージ：本人または管理者のみ ──
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == chatId || isAdmin());
    }

    // ── 全チャット検索用：collectionGroup クエリは管理者のみ ──
    match /{path=**}/messages/{messageId} {
      allow read: if request.auth != null && isAdmin();
    }

    // ── クーポン集計用：collectionGroup クエリは管理者のみ ──
    match /{path=**}/coupons/{couponId} {
      allow read: if request.auth != null && isAdmin();
    }

    // ── お知らせ：認証済みは全員読み取り、書き込みは管理者のみ ──
    match /news/{newsId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── クーポンテンプレート：認証済みは全員読み取り、書き込みは管理者のみ ──
    match /coupons/{couponId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── おみくじセット：認証済みは読み取り、書き込みは管理者のみ ──
    match /omikujiSets/{setId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── ブラックリスト：照合は Cloud Function (checkBlacklist) 経由。クライアント直接読み取りは管理者のみ ──
    match /blacklist/{docId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if request.auth != null && isAdmin();
    }

    // ── アプリ設定：管理者のみ ──
    match /settings/{docId} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // ── クーポン配信ログ：管理者のみ（天気連動クーポン配信で使用） ──
    match /couponLogs/{docId} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // ── メッセージテンプレート：管理者のみ ──
    match /messageTemplates/{templateId} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // ── バナークリック統計：認証済みユーザーが increment 可。読み取りは管理者のみ ──
    match /bannerStats/{bannerId} {
      allow read: if request.auth != null && isAdmin();
      allow create, update: if request.auth != null;
    }

    // ── Callable レート制限カウンタ（Admin SDK のみ書き込み。クライアントは不可） ──
    match /callableRateLimits/{docId} {
      allow read, write: if false;
    }
  }
}
