rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ヘルパー：管理者かどうか ──
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── ユーザー：本人のみ読み書き、管理者は全件読み取り可 ──
    match /users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
    }

    // ── ユーザー保有クーポン：本人または管理者が読み取り、本人は使用済み更新のみ、管理者は作成可 ──
    match /users/{uid}/coupons/{couponId} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && isAdmin();
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // ── チャット：本人または管理者のみ ──
    match /chats/{chatId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == chatId || isAdmin());
    }

    // ── チャットメッセージ：本人または管理者のみ ──
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == chatId || isAdmin());
    }

    // ── 全チャット検索用：collectionGroup クエリは管理者のみ ──
    match /{path=**}/messages/{messageId} {
      allow read: if request.auth != null && isAdmin();
    }

    // ── クーポン集計用：collectionGroup クエリは管理者のみ ──
    match /{path=**}/coupons/{couponId} {
      allow read: if request.auth != null && isAdmin();
    }

    // ── お知らせ：認証済みは全員読み取り、書き込みは管理者のみ ──
    match /news/{newsId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── クーポンテンプレート：認証済みは全員読み取り、書き込みは管理者のみ ──
    match /coupons/{couponId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── ブラックリスト：照合は Cloud Function (checkBlacklist) 経由。クライアント直接読み取りは管理者のみ ──
    match /blacklist/{docId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if request.auth != null && isAdmin();
    }

    // ── アプリ設定：管理者のみ ──
    match /settings/{docId} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // ── クーポン配信ログ：管理者のみ（天気連動クーポン配信で使用） ──
    match /couponLogs/{docId} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // ── メッセージテンプレート：管理者のみ ──
    match /messageTemplates/{templateId} {
      allow read, write: if request.auth != null && isAdmin();
    }
  }
}
